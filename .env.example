# GitHub Personal Access Token (fine-grained, repo scope)
GITHUB_TOKEN=ghp_your-token-here

# GitHub org or username where factory creates repos
GITHUB_OWNER=your-github-username

# Slack webhook for notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Dashboard server port
DASHBOARD_PORT=8420

# Dashboard Status API URL (used by EventEmitter to post lifecycle events)
DASHBOARD_URL=http://localhost:8420
